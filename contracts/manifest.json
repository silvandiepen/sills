{
  "version": "1.0.0",
  "contracts": [
    { "name": "audit-report", "schema": "schemas/audit-report.schema.json", "description": "Authoritative machine-readable audit report.", "generatedBy": "create-run and selected Audit Skills", "validatedBy": "packages/audit-cli/src/validate-report.mjs", "example": { "version": "1.0.0", "findings": [], "tasks": [] } },
    { "name": "finding", "schema": "schemas/finding.schema.json", "description": "Stable evidence-backed issue or positive pattern.", "generatedBy": "Audit Skills", "validatedBy": "report validation", "example": { "id": "SEC-EXAMPLE", "title": "Example finding", "severity": "low" } },
    { "name": "task", "schema": "schemas/task.schema.json", "description": "Traceable remediation task derived from findings.", "generatedBy": "Audit Skills", "validatedBy": "report validation", "example": { "id": "TASK-001", "priority": "next", "action": "Address the example finding." } },
    { "name": "conclusion", "schema": "schemas/conclusion.schema.json", "description": "Evidence-based audit status and ship decision.", "generatedBy": "Audit Skills", "validatedBy": "report validation", "example": { "level": "needs-attention", "label": "Needs attention", "summary": "Example conclusion." } },
    { "name": "audit-capability", "schema": "schemas/audit-capability.schema.json", "description": "Required and optional execution capabilities.", "generatedBy": "audit planning", "validatedBy": "contract validation", "example": { "name": "browser", "required": false } },
    { "name": "audit-coverage", "schema": "schemas/audit-coverage.schema.json", "description": "Applicable, tested, and limited audit surfaces.", "generatedBy": "Audit Skills", "validatedBy": "contract validation", "example": { "dimensions": [], "limitations": [] } },
    { "name": "audit-plan", "schema": "schemas/audit-plan.schema.json", "description": "Selected audits, shared evidence, and execution decisions.", "generatedBy": "umbrella orchestrator", "validatedBy": "contract validation", "example": { "selectedAudits": ["security"], "sharedEvidence": [], "execution": [] } },
    { "name": "audit-trend", "schema": "schemas/audit-trend.schema.json", "description": "Cross-run finding comparison.", "generatedBy": "verify and trend tooling", "validatedBy": "contract validation", "example": { "baselineComparable": true, "findings": [] } },
    { "name": "evidence-record", "schema": "schemas/evidence-record.schema.json", "description": "Reusable traceable source or runtime evidence.", "generatedBy": "collectors and Audit Skills", "validatedBy": "contract validation", "example": { "id": "EV-EXAMPLE", "type": "source", "location": "README.md" } },
    { "name": "finding-confidence", "schema": "schemas/finding-confidence.schema.json", "description": "Confidence separate from severity.", "generatedBy": "Audit Skills", "validatedBy": "contract validation", "example": { "level": "likely", "basis": "Source evidence supports the conclusion." } },
    { "name": "project-knowledge", "schema": "schemas/project-knowledge.schema.json", "description": "Shared evidence-backed project knowledge graph.", "generatedBy": "discovery and collectors", "validatedBy": "contract validation", "example": { "version": "1.0.0", "nodes": [], "relationships": [], "warnings": [] } },
    { "name": "risk-profile", "schema": "schemas/risk-profile.schema.json", "description": "Machine-readable domain risk profile.", "generatedBy": "report synthesis", "validatedBy": "contract validation", "example": { "domains": [] } },
    { "name": "content-config", "schema": "schemas/content-config.schema.json", "description": "Content-audit audience, language, and evaluation configuration.", "generatedBy": "content audit intake", "validatedBy": "contract validation", "example": { "language": "en", "audience": "general" } }
  ]
}
