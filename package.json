{
  "name": "sills-monorepo",
  "version": "0.3.0",
  "private": true,
  "description": "Engineering intelligence skills for AI coding agents.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sills-audit": "skills/sills-audit/bin/sills-audit.mjs"
  },
  "workspaces": [
    "skills/*",
    "packages/*"
  ],
  "scripts": {
    "test": "node --test",
    "validate": "node tooling/validate.mjs && node tooling/validate-contracts.mjs",
    "validate:skills": "node tooling/validate.mjs --skills",
    "validate:docs": "node tooling/validate.mjs --docs",
    "validate:contracts": "node tooling/validate-contracts.mjs",
    "build:docs": "node tooling/build-website.mjs",
    "pack:check": "node tooling/pack-check.mjs",
    "bump:changed-packages": "node tooling/bump-changed-packages.mjs",
    "publish:packages": "node tooling/publish.mjs",
    "audit:create": "node packages/audit-cli/bin/sills-audit-dev.mjs create-run",
    "audit:discover": "node packages/audit-cli/bin/sills-audit-dev.mjs discover",
    "audit:render": "node packages/audit-cli/bin/sills-audit-dev.mjs render-report"
  }
}
